# Copy to `.env` in `server/` or project root (loaded via dotenv from server cwd).

OPENAI_API_KEY=
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
PORT=37891

# Inline recent learner feedback into the coach system prompt (default on when feedback.jsonl exists).
# FEEDBACK_CONTEXT_INLINE=false
# FEEDBACK_CONTEXT_ENTRIES=14
# FEEDBACK_CONTEXT_MAX_CHARS=1600
